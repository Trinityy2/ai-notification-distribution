# ── Environment ────────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | production

# ── Security ───────────────────────────────────────────────────────────────────
# Strong random string — the bootstrap admin API key.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_ROOT_KEY=replace-me-with-a-strong-secret

# ── Repository backend ─────────────────────────────────────────────────────────
REPOSITORY_BACKEND=sqlalchemy    # sqlalchemy | in_memory

# ── Database (required when REPOSITORY_BACKEND=sqlalchemy) ────────────────────
# SQLite (dev):  sqlite+aiosqlite:///./app.db
# Postgres:      postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./app.db

# ── Hashing backend ────────────────────────────────────────────────────────────
HASHER_BACKEND=sha256            # sha256 | bcrypt

# ── Rate limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=60           # requests per window
RATE_LIMIT_WINDOW_SECONDS=60

# ── Providers ──────────────────────────────────────────────────────────────────
# Telegram — set BOT_TOKEN to enable
TELEGRAM__BOT_TOKEN=

# WhatsApp — placeholder, not yet implemented
# WHATSAPP__API_KEY=
# WHATSAPP__PHONE_NUMBER_ID=
